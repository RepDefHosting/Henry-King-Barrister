  <style>
    /* === DESIGN TOKENS === */
    :root {
      --navy:    #1B2A4A;
      --bg:      #F7F6F3;
      --accent:  #7C2432;
      --mid:     #6B7280;
      --rule:    #DDD8D0;
      --white:   #FFFFFF;
      --text:    #2C2C2C;
      --card-bg: #F0EDE8;
    }

    /* === RESET === */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      line-height: 1.7;
      color: var(--text);
      background: var(--bg);
    }
    a { color: inherit; text-decoration: none; }
    img { display: block; }

    /* === FAVICON via CSS (initials) === */
    /* Implemented via SVG favicon in <head> */

    /* === STICKY NAV === */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--navy);
      border-bottom: 3px solid var(--accent);
    }
    .nav-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 56px;
    }
    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--white);
      letter-spacing: 0.04em;
    }
    .nav-links {
      display: flex;
      list-style: none;
      gap: 2rem;
    }
    .nav-links a {
      font-size: 0.78rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.75);
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--white); }

    /* === HERO === */
    .hero {
      background: var(--navy);
      color: var(--white);
      padding: 5rem 2rem 4.5rem;
    }
    .hero-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 4rem;
      align-items: center;
    }
    .hero-label {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.1rem;
    }
    .hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.6rem, 5vw, 4rem);
      font-weight: 500;
      line-height: 1.12;
      margin-bottom: 1rem;
    }
    .hero-body {
      font-size: 0.96rem;
      color: rgba(255,255,255,0.78);
      max-width: 540px;
      line-height: 1.75;
    }
    .hero-ctas {
      margin-top: 2rem;
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .btn {
      display: inline-block;
      padding: 0.65rem 1.5rem;
      border-radius: 2px;
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      transition: all 0.2s;
      cursor: pointer;
    }
    .btn-primary {
      background: var(--accent);
      color: var(--white);
      border: 2px solid var(--accent);
    }
    .btn-primary:hover { background: #9a2d3e; border-color: #9a2d3e; }
    .btn-secondary {
      background: transparent;
      color: rgba(255,255,255,0.85);
      border: 2px solid rgba(255,255,255,0.35);
    }
    .btn-secondary:hover { border-color: rgba(255,255,255,0.7); color: #fff; }

    /* Photo */
    .hero-photo-wrap {
      position: relative;
    }
    .hero-photo {
      width: 100%;
      max-width: 380px;
      height: auto;
      border-radius: 3px;
      display: block;
      margin-left: auto;
      box-shadow: 0 20px 60px rgba(0,0,0,0.4);
      border: 4px solid rgba(255,255,255,0.08);
    }
    .hero-photo-accent {
      position: absolute;
      bottom: -12px;
      right: -12px;
      width: 80px;
      height: 80px;
      background: var(--accent);
      border-radius: 2px;
      z-index: -1;
    }

    /* === SECTION WRAPPER === */
    .section {
      padding: 4.5rem 2rem;
    }
    .section-inner {
      max-width: 1100px;
      margin: 0 auto;
    }
    .section-alt { background: var(--card-bg); }

    /* === SECTION LABELS / HEADINGS === */
    .section-label {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.6rem;
    }
    h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      font-weight: 500;
      color: var(--navy);
      line-height: 1.2;
      margin-bottom: 1.5rem;
    }
    .section-rule {
      width: 40px;
      height: 3px;
      background: var(--accent);
      margin-bottom: 2rem;
    }

    /* === OVERVIEW (two-col) === */
    .overview-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: start;
    }
    .overview-text p {
      color: var(--mid);
      font-size: 0.97rem;
      line-height: 1.8;
      margin-bottom: 1rem;
    }
    .stat-row {
      display: flex;
      gap: 2.5rem;
      margin-top: 2rem;
    }
    .stat { }
    .stat-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.8rem;
      font-weight: 600;
      color: var(--navy);
      line-height: 1;
    }
    .stat-label {
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      color: var(--mid);
      text-transform: uppercase;
      margin-top: 0.3rem;
    }
    .overview-bio {
      padding: 2rem 2.2rem;
      background: var(--navy);
      color: rgba(255,255,255,0.82);
      border-radius: 2px;
      font-size: 0.95rem;
      line-height: 1.8;
      border-left: 4px solid var(--accent);
    }
    .overview-bio p { margin-bottom: 0.9rem; }
    .overview-bio p:last-child { margin-bottom: 0; }

    /* === PRACTICE CARDS === */
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
      margin-top: 1.5rem;
    }
    .card {
      background: var(--white);
      border: 1px solid var(--rule);
      border-top: 3px solid var(--navy);
      padding: 1.6rem 1.4rem 1.8rem;
      border-radius: 2px;
      transition: box-shadow 0.2s;
    }
    .card:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.07); }
    .card-icon {
      width: 36px;
      height: 36px;
      background: var(--navy);
      border-radius: 2px;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .card-icon svg { width: 18px; height: 18px; stroke: white; fill: none; stroke-width: 1.8; }
    .card h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--navy);
      margin-bottom: 0.55rem;
    }
    .card p {
      font-size: 0.84rem;
      color: var(--mid);
      line-height: 1.65;
    }

    /* === COSTS SECTION === */
    .costs-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }
    .costs-body p {
      font-size: 0.97rem;
      color: var(--mid);
      line-height: 1.8;
      margin-bottom: 1rem;
    }
    .costs-callout {
      background: var(--white);
      border: 1px solid var(--rule);
      padding: 2rem;
      border-radius: 2px;
    }
    .costs-callout h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--navy);
      margin-bottom: 1rem;
    }
    .costs-callout ul {
      list-style: none;
    }
    .costs-callout li {
      font-size: 0.88rem;
      color: var(--mid);
      padding: 0.55rem 0;
      border-bottom: 1px solid var(--rule);
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
    }
    .costs-callout li:last-child { border-bottom: none; }
    .costs-callout li::before {
      content: '';
      display: block;
      width: 6px;
      height: 6px;
      background: var(--accent);
      border-radius: 50%;
      margin-top: 0.5rem;
      flex-shrink: 0;
    }

    /* === COMMERCIAL EXPERIENCE === */
    .experience-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 2rem;
    }
    .exp-item {
      background: var(--white);
      border: 1px solid var(--rule);
      padding: 1.4rem 1.3rem;
      border-radius: 2px;
    }
    .exp-item h4 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.05rem;
      font-weight: 600;
      color: var(--navy);
      margin-bottom: 0.4rem;
    }
    .exp-item p {
      font-size: 0.83rem;
      color: var(--mid);
      line-height: 1.6;
    }
    .claim-range {
      margin-top: 2rem;
      background: var(--navy);
      color: white;
      padding: 1.5rem 2rem;
      border-radius: 2px;
      display: flex;
      align-items: center;
      gap: 3rem;
    }
    .range-item { }
    .range-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem;
      font-weight: 600;
      color: white;
    }
    .range-label {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.6);
      text-transform: uppercase;
      letter-spacing: 0.07em;
      margin-top: 0.2rem;
    }
    .range-sep {
      width: 1px;
      height: 48px;
      background: rgba(255,255,255,0.15);
    }

    /* === BACKGROUND / EDUCATION === */
    .bg-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
    .edu-block {
      display: flex;
      gap: 1.2rem;
      align-items: flex-start;
      padding: 1.4rem 0;
      border-bottom: 1px solid var(--rule);
    }
    .edu-block:first-of-type { border-top: 1px solid var(--rule); }
    .edu-icon {
      width: 40px;
      height: 40px;
      background: var(--bg);
      border: 1px solid var(--rule);
      border-radius: 2px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .edu-icon svg { width: 18px; height: 18px; stroke: var(--navy); fill: none; stroke-width: 1.6; }
    .edu-label {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--mid);
      margin-bottom: 0.2rem;
    }
    .edu-value {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--navy);
      line-height: 1.3;
    }
    .edu-sub {
      font-size: 0.85rem;
      color: var(--mid);
      margin-top: 0.2rem;
    }
    .fitness-block {
      background: var(--white);
      border: 1px solid var(--rule);
      padding: 2rem;
      border-radius: 2px;
    }
    .fitness-block p {
      font-size: 0.95rem;
      color: var(--mid);
      line-height: 1.8;
      margin-bottom: 1rem;
    }
    .fitness-block p:last-child { margin-bottom: 0; }
    .run-badges {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-top: 1.2rem;
    }
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.78rem;
      font-weight: 500;
      padding: 0.35rem 0.8rem;
      border: 1px solid var(--rule);
      border-radius: 100px;
      color: var(--navy);
      background: var(--bg);
    }
    .badge::before {
      content: '●';
      font-size: 0.5rem;
      color: var(--accent);
    }

    /* === PROFILES === */
    .profiles-list {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.75rem;
    }
    .profile-link {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.6rem;
      padding: 1.2rem 0.75rem;
      border: 1px solid var(--rule);
      background: var(--white);
      border-radius: 2px;
      text-decoration: none;
      color: var(--navy);
      transition: all 0.15s;
      text-align: center;
    }
    .profile-link:hover { border-color: var(--accent); box-shadow: 0 4px 16px rgba(0,0,0,0.07); }
    .profile-link:hover .pl-icon { background: var(--accent); }
    .pl-icon {
      width: 36px;
      height: 36px;
      background: var(--navy);
      border-radius: 2px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: background 0.15s;
    }
    .pl-icon svg { width: 15px; height: 15px; stroke: white; fill: none; stroke-width: 1.8; }
    .pl-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.95rem;
      font-weight: 600;
      line-height: 1.3;
    }
    .pl-arrow { display: none; }

    /* === RESOURCES === */
    .resources-body {
      max-width: 680px;
    }
    .resources-body p {
      font-size: 0.97rem;
      color: var(--mid);
      line-height: 1.8;
      margin-bottom: 1rem;
    }

    /* === FOOTER === */
    footer {
      background: var(--navy);
      color: rgba(255,255,255,0.55);
      padding: 2.5rem 2rem;
      border-top: 3px solid var(--accent);
    }
    .footer-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
      flex-wrap: wrap;
    }
    .footer-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      font-weight: 600;
      color: rgba(255,255,255,0.85);
    }
    .footer-text {
      font-size: 0.8rem;
      line-height: 1.6;
      max-width: 500px;
    }

    /* === SCHEMA / PERSONAL INTERESTS hidden section === */
    .interests-row {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-top: 1.2rem;
    }

    /* === RESPONSIVE === */
    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; }
      .hero-photo { max-width: 100%; margin: 0 auto; }
      .hero-photo-accent { display: none; }
      .overview-grid, .costs-inner, .bg-grid { grid-template-columns: 1fr; gap: 2rem; }
      .cards-grid { grid-template-columns: repeat(2, 1fr); }
      .experience-grid { grid-template-columns: repeat(2, 1fr); }
      .profiles-list { grid-template-columns: repeat(2, 1fr); }
      .nav-links { display: none; }
      .claim-range { flex-direction: column; gap: 1rem; }
      .range-sep { display: none; }
    }
    @media (max-width: 560px) {
      .cards-grid { grid-template-columns: 1fr; }
      .experience-grid { grid-template-columns: 1fr; }
      .stat-row { flex-direction: column; gap: 1.5rem; }
    }
  </style>

